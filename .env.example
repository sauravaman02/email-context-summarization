# Database (SQLite used by default if DATABASE_URL is not set)
DATABASE_URL=sqlite+aiosqlite:///./email_context.db
# For PostgreSQL: DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/email_context

# Authentication
JWT_SECRET_KEY=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your-fernet-key-here

# Gemini API
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Cache
CACHE_TTL_SECONDS=1800

# Summarization
SUMMARIZATION_MIN_NEW_EMAILS=5
SUMMARIZATION_MAX_RETRIES=3
SUMMARIZATION_RETRY_BASE_DELAY=1.0

# Logging
LOG_LEVEL=INFO
